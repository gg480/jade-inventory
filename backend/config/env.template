# ══════════════════════════════════════════════
#  玉器进销存系统 — 配置文件（持久化）
# ══════════════════════════════════════════════
#
# 此文件由容器首次启动时自动生成。
# 修改后需重启容器才能生效。
#
# 加载优先级：
#   docker-compose environment > 本文件 > 系统默认值
# （environment 里已设置的值不会被本文件覆盖）
#
# ──────────────── 必须配置 ────────────────

# JWT 签名密钥（必须修改！至少16位随机字符串）
# 可用命令生成：python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=please-change-this-to-a-random-string

# ──────────────── 可选配置 ────────────────

# 默认管理员密码（仅首次初始化数据库时生效，之后在系统内修改）
# DEFAULT_ADMIN_PASSWORD=admin888

# JWT Token 有效天数
# JWT_EXPIRE_DAYS=30

# 压货预警天数（超过此天数的库存会标记为压货预警）
# ALERT_DAYS=90

# 调试模式（开启后会记录每个API请求的耗时）
# DEBUG=false

# 时区
# TZ=Asia/Shanghai
