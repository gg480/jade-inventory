# ── 玉器进销存系统配置文件 ──
# 复制此文件为 .env，修改需要的值即可
#
# 加载优先级：
#   docker-compose.yml environment > config/.env > 系统默认值
# 即：environment 里已设置的值不会被 .env 覆盖

# [必改] JWT 签名密钥（至少16位随机字符串）
JWT_SECRET=your-random-secret-here

# [可选] 默认管理员密码（仅首次启动时生效，之后在系统内修改）
# DEFAULT_ADMIN_PASSWORD=admin123

# [可选] JWT Token 有效天数
# JWT_EXPIRE_DAYS=30

# [可选] 压货预警天数
# ALERT_DAYS=90

# [可选] 开启调试日志
# DEBUG=false
