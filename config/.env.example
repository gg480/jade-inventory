# ── 玉器进销存系统 — 环境变量配置 ──
# 极空间部署时，将此文件放到 ./config/ 目录下

# [必改] JWT 密钥（请替换为随机字符串，修改后需重新登录）
JWT_SECRET=change-this-to-a-random-string

# [可选] CORS 允许的来源（* 表示允许所有，生产环境建议改为实际域名）
CORS_ORIGINS=*

# [可选] 时区
TZ=Asia/Shanghai

# [可选] 数据库路径（容器内路径，一般不需要修改）
DB_PATH=/app/data/jade.db

# [可选] 图片存储目录（容器内路径，一般不需要修改）
IMAGE_DIR=/app/data/images

# [可选] JWT Token 有效天数（默认30天）
JWT_EXPIRE_DAYS=30

# [可选] 压货预警天数阈值（默认90天）
ALERT_DAYS=90

# [可选] 默认分页大小（默认20条）
DEFAULT_PAGE_SIZE=20

# [可选] 图片最大大小（单位：字节，默认5MB=5242880）
MAX_IMAGE_SIZE=5242880

# [调试] 开启调试日志（true/false，生产环境请设为false）
DEBUG=false

# [危险] 设为 true 会删除所有表并重建（仅用于开发调试）
# RESET_DB=true
