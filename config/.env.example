# ── 玉器进销存系统配置 ──
# 复制此文件为 .env 并修改需要的值，然后和 docker-compose.yml 一起上传到极空间

# [必改] JWT 密钥，改成任意随机字符串（修改后需重新登录）
JWT_SECRET=change-this-to-a-random-string

# [一般不改] CORS 允许的来源
CORS_ORIGINS=*

# [一般不改] 时区
TZ=Asia/Shanghai

# [一般不改] 数据库路径（容器内）
DB_PATH=/app/data/jade.db

# [一般不改] 图片存储目录（容器内）
IMAGE_DIR=/app/data/images

# [可选] JWT Token 有效天数，默认30
JWT_EXPIRE_DAYS=30

# [可选] 压货预警天数，默认90
ALERT_DAYS=90

# [调试] true 开启请求日志
DEBUG=false
